{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@polpo-ai/chat": ["../chat/src/index.ts"],
      "@polpo-ai/chat/*": ["../chat/src/*"]
    }
  },
  "include": ["src"]
}
